<!DOCTYPE html>
<html>
  <head>
    <title>Home Assistant</title>
    <%= renderTemplate("_header.html.template") %>
    <%= renderTemplate("_style_base.html.template") %>
    <style>
      /* 【修改】全屏布局 - 对齐登录界面样式 */
      html {
        background-color: #0a0f1c;
        color: #e1e1e1;
        height: 100%;
      }

      body {
        box-sizing: border-box;
        padding: 0;
        margin: 0;
        display: block;
        height: 100vh;
        width: 100vw;
        overflow: hidden;
        /* 【修改】深色渐变背景 */
        background: linear-gradient(135deg, #0a0f1c 0%, #111827 25%, #1a2236 50%, #111827 75%, #0a0f1c 100%);
      }

      /* 【修改】让 content 容器负责全屏布局 */
      .content {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        height: 100vh;
        display: flex;
        flex-direction: row;
      }

      /* 【修改】隐藏原有的 header，因为左侧宣传区已有品牌展示 */
      .header {
        display: none;
      }
    </style>
  </head>
  <body id="particles">
    <div class="content">
      <div class="header">
        <img src="/static/icons/favicon-192x192.png" alt="Home Assistant" />
      </div>
      <ha-onboarding></ha-onboarding>
    </div>
    <%= renderTemplate("_js_base.html.template") %>
    <%= renderTemplate("_preload_roboto.html.template") %>
    <%= renderTemplate("_script_loader.html.template") %>
    <script crossorigin="use-credentials">
      if (window.latestJS) {
        window.stepsPromise = fetch("<%= hassUrl %>/api/onboarding", {
          credentials: "same-origin",
        });
      }
    </script>
  </body>
</html>
