<!DOCTYPE html>
<html>
  <head>
    <title>Xo Ai</title>
    <%= renderTemplate("_header.html.template") %>
    <%= renderTemplate("_style_base.html.template") %>
    <style>
      html {
        /* 【修改】直接使用深色背景 */
        background-color: #0a0f1c;
        color: #e1e1e1;
        height: 100%;
      }
      body {
        box-sizing: border-box;
        padding: 0;
        margin: 0;
        display: block;
        height: 100vh;
        width: 100vw;
        overflow: hidden;
        /* 【新增】确保 body 也是深色背景 */
        background: linear-gradient(135deg, #0a0f1c 0%, #111827 25%, #1a2236 50%, #111827 75%, #0a0f1c 100%);
      }

      /* 让 content 容器负责左右分栏布局 */
      .content {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        height: 100vh;
        display: flex;
        flex-direction: row;
      }

      .header {
        display: none; /* 隐藏原有的 logo header，因为 ha-authorize 内部已有宣传区 */
      }
    </style>
  </head>
  <body>
    <div class="content">
      <ha-authorize></ha-authorize>
    </div>
    <%= renderTemplate("_js_base.html.template") %>
    <%= renderTemplate("_preload_roboto.html.template") %>
    <%= renderTemplate("_script_loader.html.template") %>
    <script crossorigin="use-credentials">
      if (window.latestJS) {
        window.providersPromise = fetch("<%= hassUrl %>/auth/providers", {
          credentials: "same-origin",
        });
      }
    </script>
  </body>
</html>
